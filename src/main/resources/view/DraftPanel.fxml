               <Label text="/" styleClass="field-value" />
               <HBox spacing="2" alignment="CENTER_LEFT">
                  <Label fx:id="jungleDeaths" styleClass="field-value" />
               </HBox>
               <Label text="/" styleClass="field-value" />
               <HBox spacing="2" alignment="CENTER_LEFT">
                  <Label fx:id="jungleAssists" styleClass="field-value" />
               </HBox>
               <HBox spacing="2" alignment="CENTER_LEFT">
                  <Label text="(" styleClass="field-value" />
                  <Label fx:id="jungleKdRatio" styleClass="field-value" />
                  <Label text=")" styleClass="field-value" />
               </HBox>
            </HBox>
         </VBox>

         <!-- Entity Buttons -->
         <VBox spacing="3" VBox.vgrow="ALWAYS">
            <Label text="Champions:" styleClass="field-label" />
            <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" styleClass="entity-scroll-pane">
               <FlowPane fx:id="jungleEntityFlowPane" hgap="5" vgap="5" styleClass="entity-flow-pane" />
            </ScrollPane>
         </VBox>
      </VBox>
   </VBox>

   <!-- MID Player Panel -->
