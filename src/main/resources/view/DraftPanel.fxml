<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<HBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" spacing="10">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>

   <!-- TOP Player Panel -->
   <VBox HBox.hgrow="ALWAYS" prefWidth="180" styleClass="panel-with-border" spacing="5">
      <padding>
         <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
      </padding>

      <Label fx:id="topName" styleClass="player-comparison-name">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>

      <VBox spacing="4">
         <Label text="Role:" styleClass="field-label" />
         <Label fx:id="topRole" styleClass="field-value" />

         <Label text="Rank:" styleClass="field-label" />
         <Label fx:id="topRank" styleClass="field-value" />

         <!-- Combined KDA Line -->
         <VBox spacing="3">
            <Label text="Overall Stats:" styleClass="field-label" />
            <HBox spacing="5" alignment="CENTER_LEFT">
               <HBox spacing="2" alignment="CENTER_LEFT">
                  <Label fx:id="topKills" styleClass="field-value" />
               </HBox>
               <Label text="/" styleClass="field-value" />
               <HBox spacing="2" alignment="CENTER_LEFT">
                  <Label fx:id="topDeaths" styleClass="field-value" />
               </HBox>
               <Label text="/" styleClass="field-value" />
               <HBox spacing="2" alignment="CENTER_LEFT">
                  <Label fx:id="topAssists" styleClass="field-value" />
               </HBox>
               <HBox spacing="2" alignment="CENTER_LEFT">
                  <Label text="(" styleClass="field-value" />
                  <Label fx:id="topKdRatio" styleClass="field-value" />
                  <Label text=")" styleClass="field-value" />
               </HBox>
            </HBox>
         </VBox>

         <!-- Entity Buttons -->
         <VBox spacing="3" VBox.vgrow="ALWAYS">
            <Label text="Champions:" styleClass="field-label" />
            <ScrollPane fitToWidth="true" fitToHeight="true" VBox.vgrow="ALWAYS" styleClass="entity-scroll-pane">
               <FlowPane fx:id="topEntityFlowPane" hgap="5" vgap="5" styleClass="entity-flow-pane" />
            </ScrollPane>
         </VBox>
      </VBox>
   </VBox>

   <!-- JUNGLE Player Panel -->
